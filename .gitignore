# =============================================================
#  UMG Bus App — .gitignore
#  CRITICAL: Never commit .env files (real credentials inside)
# =============================================================
CLAUDE.md
INFO.md

# ─── Environment / Secrets ───────────────────────────────────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ─── Go ──────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
/server
/server.exe
backend/server.exe
# Compiled binary named 'server' at root of backend (not directories named server)
backend/server[^/]

# Go test artifacts
*.test
*.out
coverage.txt
coverage.html

# Go build cache (local)
/vendor/

# ─── Node / Frontend ─────────────────────────────────────────
node_modules/
**/node_modules/
dist/
build/
.next/
out/
.nuxt/
.output/

# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json.bak

# Vite cache
.vite/
**/.vite/

# ─── Python ──────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
*.egg
.venv/
venv/
env/

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/
**/logs/
*.log.*
npm-debug.log
yarn-debug.log

# ─── OS / System ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE / Editors ───────────────────────────────────────────
# VSCode — keep shared settings, ignore personal ones
.vscode/settings.json
.vscode/*.code-workspace
.vscode/launch.json
.vscode/tasks.json
.vscode/.ropeproject
# Keep: .vscode/extensions.json (team recommendations)

# JetBrains (GoLand, WebStorm, IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.#*

# ─── Docker ──────────────────────────────────────────────────
# Keep docker-compose.yml — ignore override files with secrets
docker-compose.override.yml
docker-compose.local.yml
.docker/

# ─── Database / Migrations ───────────────────────────────────
*.dump
*.sql.gz
pgdata/
redisdata/

# ─── Miscellaneous ───────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej
.cache/
tmp/
temp/
